{
  "name": "photosbyperkins",
  "private": true,
  "version": "1.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,scss}\"",
    "clean": "node scripts/cleanDist.js",
    "build": "npm run clean && npm run format && tsc && npm run index && npm run webp && npm run thumbnails && npm run favicon && node scripts/processAndCopyPhotos.js && npm run faces && npm run wftda && npm run chunk-data && vite build && node scripts/generateSitemap.js && node scripts/generateSharePages.js",
    "deploy": "node scripts/deploy.js",
    "fix-permissions": "node scripts/fixPermissions.js",
    "faces": "python scripts/detectFaces.py",
    "index": "node scripts/generatePhotoIndex.js",
    "thumbnails": "node scripts/generateThumbnails.js",
    "favicon": "node scripts/generate_favicon.js",
    "webp": "node scripts/generateWebp.js",
    "zips": "node scripts/generateZips.js",
    "wftda": "node scripts/scrapeWftda.js",
    "chunk-data": "node scripts/chunkData.js",
    "populate-scores": "node scripts/populateEventScores.js",
    "rename": "node scripts/renamePhotoFolders.js",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "exifr": "^7.1.3",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "puppeteer": "^24.41.0",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4",
    "zustand": "^5.0.12"
  },
  "dependencies": {
    "@fontsource/barlow-condensed": "^5.2.8",
    "@fontsource/oswald": "^5.2.8",
    "@fontsource/outfit": "^5.2.8",
    "@nrs-binding/ssimulacra2": "^1.0.23",
    "archiver": "^7.0.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.14.1",
    "sass": "^1.99.0"
  }
