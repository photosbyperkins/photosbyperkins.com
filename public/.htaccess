<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !\.zip$ [NC]
  RewriteRule . /index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # 1. Never cache HTML/JSON data or Service Workers (always fetch fresh)
  <FilesMatch "\.(html|json)$|sw\.js|^workbox-.*\.js$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # 2. Aggressively cache Vite's hashed assets (JS, CSS) for 1 year
  <If "%{REQUEST_URI} =~ m#^/assets/.*#">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </If>

  # 3. Cache images normally (1 day)
  <FilesMatch "\.(jpeg|jpg|png|gif|svg|webp|avif|ico)$">
    Header set Cache-Control "public, max-age=86400, stale-while-revalidate=604800"
  </FilesMatch>

  # 4. Serve zip files as downloads with correct MIME type
  <FilesMatch "\.zip$">
    Header set Content-Type "application/zip"
    Header set Content-Disposition "attachment"
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

<IfModule mod_mime.c>
  AddType application/zip .zip
</IfModule>
