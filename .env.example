# Deployment Config
# These variables control where `npm run deploy` sends the build output over SSH.
DEPLOY_SSH_USER=your_username
DEPLOY_SSH_HOST=your_ip_or_domain
DEPLOY_REMOTE_DIR=/home/username/public_html

# Branding and SEO Config
# These are baked into the site at build time (`npm run build`). 
VITE_SITE_DOMAIN=yourdomain.com
VITE_PWA_NAME="Photography by Jane Doe"
VITE_PWA_SHORT_NAME="Jane's Photos"
VITE_PWA_THEME_COLOR="#1a1a1a"
VITE_PWA_DESC="Action Photography by Jane Doe"

VITE_SITE_TITLE="Jane's Photos | Action Photography"
VITE_SITE_APP_TITLE="Jane's Photos"
VITE_SITE_DESC="Jane Doe, Local Action Photographer. Capturing the speed, power, and heart of sports."
VITE_SITE_KEYWORDS="Jane Doe, photography, action sports photography"
VITE_OG_TITLE="Jane's Photos | Action Photography"
VITE_OG_DESC="Capturing the speed, power, and emotion of sports."

# UI String Replacements
VITE_COPYRIGHT_NAME="Jane Doe Photography"
VITE_LICENSE_LABEL="Photos licensed under CC BY-SA 4.0"
VITE_LICENSE_URL="https://creativecommons.org/licenses/by-sa/4.0/"
VITE_ABOUT_ME="Hey, I'm Jane! I've been taking photos since 2020. \n\nI love capturing the raw action of competitive sports and bringing high-quality dynamic shots to the local leagues. Check out my work!"
VITE_TEAM_ABBREVIATIONS='{"My Local Roller Derby":"MLRD","Rival City Roller Derby":"Rival City","Long Name League":"LNL","Headshots":""}'
